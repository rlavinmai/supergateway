    "msftteamsnotificationhttpmcpserver": {
      "transport": "streamableHttp",
      "url": "http://host.docker.internal:5008/mcp",
      "forceProtocolVersion": "2024-11-05"
    },
    "image2mcp": {
      "transport": "streamableHttp",
      "url": "http://host.docker.internal:5016/mcp",
      "oauth2BearerEnv": "IMAGE2MCP_BEARER_TOKEN",
      "forceProtocolVersion": "2024-11-05"
    },
    "zendesk-mcp": {
      "transport": "streamableHttp",
