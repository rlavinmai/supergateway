    "msft-email-mcp": {
      "transport": "streamableHttp",
      "url": "http://localhost:5010/mcp",
      "oauth2BearerEnv": "MSFT_EMAIL_MCP_AUTH_TOKEN",
      "forceProtocolVersion": "2024-11-05"
    }
  }
}
