{
  "servers": {
    "onetrustmcpserver": {
      "transport": "streamableHttp",
      "url": "https://host.docker.internal:5003/mcp",
      "oauth2BearerEnv": "ONETRUST_MCP_API_TOKEN",
      "forceProtocolVersion": "2024-11-05",
      "env": {
        "NODE_TLS_REJECT_UNAUTHORIZED": "0"
      }
    },
    "projectplace-mcp": {
      "transport": "streamableHttp",
      "url": "http://localhost:5017/mcp",
      "forceProtocolVersion": "2024-11-05"
    },
    "agileplace-mcp": {
      "transport": "streamableHttp",
      "url": "https://localhost:5018/mcp/",
      "oauth2BearerEnv": "AGILEPLACE_MCP_AUTH_TOKEN",
      "forceProtocolVersion": "2024-11-05",
      "env": {
        "NODE_TLS_REJECT_UNAUTHORIZED": "0"
      }
    },
    "sqlmcpserverdocker": {
      "transport": "streamableHttp",
      "url": "http://host.docker.internal:5000/mcp"
    },
    "phase-1-lucid-mcp": {
      "transport": "streamableHttp",
      "url": "http://host.docker.internal:5004/mcp",
      "oauth2BearerEnv": "LUCID_MCP_BEARER_TOKEN"
    },
    "azure-observability-mcp": {
      "transport": "streamableHttp",
